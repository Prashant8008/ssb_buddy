# Copy to .env for local production testing, or set via `fly secrets set` on Fly.io.

DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=change-me-to-a-long-random-string

# Comma-separated hosts, e.g. ssb-buddy-api.fly.dev
ALLOWED_HOSTS=ssb-buddy-api.fly.dev

# PostgreSQL (Fly Postgres, Neon, Supabase, etc.)
DATABASE_URL=1
POSTGRES_DB=ssb_connect
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=5432

# MongoDB Atlas — required for feed posts/comments/likes
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=ssb_connect_feed

# Redis — required for WebSockets in production
REDIS_URL=redis://default:pass@host:6379
CHANNEL_LAYER_BACKEND=channels_redis.core.RedisChannelLayer

# Groq AI features
GROQ_API_KEY=

# Frontend origin(s) — comma-separated
CORS_ALLOWED_ORIGINS=https://your-frontend.pages.dev
CSRF_TRUSTED_ORIGINS=https://your-frontend.pages.dev

# Email (optional)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=SSB Connect <no-reply@example.com>

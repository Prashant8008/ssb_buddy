# Local: copy to backend/.env
# Production: set in Render dashboard (or Railway / Fly).

DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=change-me-to-a-long-random-string

# Render sets RENDER_EXTERNAL_HOSTNAME automatically. Railway sets RAILWAY_PUBLIC_DOMAIN.
ALLOWED_HOSTS=.onrender.com

# PostgreSQL — Render/Railway inject DATABASE_URL when linked.
DATABASE_URL=postgresql://user:pass@host:5432/ssb_connect

# MongoDB Atlas — required for feed posts/comments/likes
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=ssb_connect_feed

# Redis — required for WebSockets (Render Redis or Railway Redis plugin)
REDIS_URL=redis://default:pass@host:6379
CHANNEL_LAYER_BACKEND=channels_redis.core.RedisChannelLayer

# Groq AI features
GROQ_API_KEY=

# Cloudinary Integration (Optional: if empty, defaults to local media folder storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend URL(s) — comma-separated, include https://
# Netlify: https://your-site.netlify.app
# Vercel:  https://your-site.vercel.app
CORS_ALLOWED_ORIGINS=https://your-frontend.netlify.app
CSRF_TRUSTED_ORIGINS=https://your-frontend.netlify.app

# Email (optional)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=SSB Connect <no-reply@example.com>

# --- Frontend env (Netlify / Vercel dashboard, NOT backend/.env) ---
# VITE_API_BASE_URL=https://YOUR-RENDER-SERVICE.onrender.com/api

# --- Render Blueprint (render.yaml) ---
# Deploy: Render → New → Blueprint → connect repo
# After deploy, set sync:false vars: MONGO_URI, CORS/CSRF origins, GROQ, Cloudinary

# --- Railway reference (alternative) ---
# Backend: DATABASE_URL=${{Postgres.DATABASE_URL}}, REDIS_URL=${{Redis.REDIS_URL}}
# Frontend: VITE_API_BASE_URL=https://${{Backend.RAILWAY_PUBLIC_DOMAIN}}/api

# Local: copy to backend/.env
# Railway: set these as service variables in the dashboard (or link plugins).

DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=change-me-to-a-long-random-string

# Railway sets RAILWAY_PUBLIC_DOMAIN automatically — also add your custom domain if used.
ALLOWED_HOSTS=.up.railway.app

# Railway PostgreSQL plugin injects DATABASE_URL automatically when linked.
DATABASE_URL=postgresql://user:pass@host:5432/railway

# MongoDB Atlas — required for feed posts/comments/likes
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=ssb_connect_feed

# Railway Redis plugin injects REDIS_URL when linked — required for WebSockets
REDIS_URL=redis://default:pass@host:6379
CHANNEL_LAYER_BACKEND=channels_redis.core.RedisChannelLayer

# Groq AI features
GROQ_API_KEY=

# Cloudinary Integration (Optional: if empty, defaults to local media folder storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend Railway URL(s) — comma-separated, include https://
CORS_ALLOWED_ORIGINS=https://your-frontend.up.railway.app
CSRF_TRUSTED_ORIGINS=https://your-frontend.up.railway.app

# Email (optional)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=SSB Connect <no-reply@example.com>

# --- Railway reference variables (set in dashboard, not in this file) ---
# Backend service:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
#   REDIS_URL=${{Redis.REDIS_URL}}
#   CORS_ALLOWED_ORIGINS=https://${{Frontend.RAILWAY_PUBLIC_DOMAIN}}
#   CSRF_TRUSTED_ORIGINS=https://${{Frontend.RAILWAY_PUBLIC_DOMAIN}}
# Frontend service:
#   VITE_API_BASE_URL=https://${{Backend.RAILWAY_PUBLIC_DOMAIN}}/api

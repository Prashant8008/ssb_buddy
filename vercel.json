{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm ci && npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "env": {
    "VITE_API_BASE_URL": "https://ssb-connect.onrender.com/api"
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
